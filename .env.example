DATABASE_URL=
CONTACT_RATE_LIMIT_MAX=10
CONTACT_RATE_LIMIT_WINDOW_MS=900000
CONTACT_RETENTION_DAYS=90
CORS_ORIGINS=https://your-site.netlify.app

# Secret pepper for the HMAC-SHA256 rate-limit IP hash. Required everywhere
# (the limiter fails closed without it). Any long random string:
#   openssl rand -hex 32
RATE_LIMIT_PEPPER=

# Cloudflare Turnstile (secret key; the public site key lives in the HTML).
# Required in production -- the function fails closed without it.
TURNSTILE_SECRET=

# SMTP
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
CONTACT_NOTIFY_TO=
