NODE_ENV=development
PORT=3000
TRUST_PROXY_HOPS=1

# Legacy local server runtime only. Vercel serverless uses root `.env.example`.

# Relative paths are resolved from the server directory.
DB_PATH=./data/podcast.db
DB_BACKUP_DIR=./data/backups
DATA_RETENTION_DAYS=90
RETENTION_SWEEP_INTERVAL_MS=3600000

CORS_ORIGINS=http://localhost:8000,http://localhost:3000

CONTACT_RATE_LIMIT_WINDOW_MS=900000
CONTACT_RATE_LIMIT_MAX=10

# For distributed rate limiting in production.
REDIS_URL=

# Vercel serverless path (api/contact.js) uses Postgres.
DATABASE_URL=

# Captcha optional in local development.
CAPTCHA_VERIFY_URL=
CAPTCHA_SECRET=

# SMTP (required in production)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
CONTACT_NOTIFY_TO=

# Observability
METRICS_ENABLED=true
METRICS_REQUIRE_TOKEN=false
METRICS_TOKEN=
ALERT_WEBHOOK_URL=
ALERT_TIMEOUT_MS=3000

# Admin API
ADMIN_API_TOKEN=
